# OpenCTI AssemblyLine Import Connector - Environment Variables
# Copy this file to .env and update with your settings

# ===========================================
# OpenCTI Connection
# ===========================================
OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=your-opencti-admin-token

# ===========================================
# Connector Settings
# ===========================================
# Generate a unique UUID v4 for this connector
# You can use: python -c "import uuid; print(uuid.uuid4())"
ASSEMBLYLINE_IMPORT_CONNECTOR_ID=your-unique-uuid-v4

CONNECTOR_TYPE=EXTERNAL_IMPORT
CONNECTOR_NAME=AssemblyLine Import
CONNECTOR_SCOPE=assemblyline
CONNECTOR_AUTO=true
CONNECTOR_CONFIDENCE_LEVEL=80
CONNECTOR_LOG_LEVEL=info

# ===========================================
# AssemblyLine Connection
# ===========================================
ASSEMBLYLINE_URL=https://your-assemblyline-instance
ASSEMBLYLINE_USER=opencti-connector
ASSEMBLYLINE_APIKEY=your-assemblyline-api-key
ASSEMBLYLINE_VERIFY_SSL=false

# ===========================================
# Import Settings
# ===========================================
# How often to run the import (in seconds)
ASSEMBLYLINE_IMPORT_INTERVAL=240

# How many days back to search for submissions
ASSEMBLYLINE_LOOKBACK_DAYS=1

# TLP marking for all created objects
# Options: TLP:RED, TLP:AMBER, TLP:GREEN, TLP:WHITE, TLP:CLEAR
ASSEMBLYLINE_TLP_LEVEL=TLP:AMBER

# Include suspicious IOCs (not just malicious)
ASSEMBLYLINE_INCLUDE_SUSPICIOUS=false

# ===========================================
# Feature Toggles
# ===========================================
# Create indicators for malicious domains, IPs, URLs
ASSEMBLYLINE_CREATE_NETWORK_INDICATORS=true

# Create observables with based-on relationships to indicators
ASSEMBLYLINE_CREATE_OBSERVABLES=true

# Create Malware Analysis objects (visible in OpenCTI's dedicated section)
ASSEMBLYLINE_CREATE_MALWARE_ANALYSIS=true

# Create Malware family entities
ASSEMBLYLINE_CREATE_MALWARE_ENTITIES=true

# Create MITRE ATT&CK patterns
ASSEMBLYLINE_CREATE_ATTACK_PATTERNS=true

# Create files as Artifacts (true) or StixFile (false)
ASSEMBLYLINE_CREATE_AS_ARTIFACT=true
